# Enable Gzip/Brotli compression for text assets
<IfModule mod_deflate.c>
  AddType application/javascript js
  AddType text/css css
  AddType application/json json
  AddType text/html html
  
  AddOutputFilterByType DEFLATE application/javascript text/css text/html application/json
  AddOutputFilterByType DEFLATE text/plain text/xml
  AddOutputFilterByType DEFLATE application/xml application/xhtml+xml
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# Enable browser caching
<IfModule mod_expires.c>
  ExpiresActive On

  # Images - cache for 1 year (60 * 60 * 24 * 365)
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType image/vnd.microsoft.icon "access plus 1 year"

  # Fonts - cache for 1 year (Google Fonts, custom fonts)
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType font/otf "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"

  # CSS and JavaScript - cache for 1 year (versioned by build)
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"
  ExpiresByType application/json "access plus 1 year"

  # HTML and default - cache for 1 week (to allow updates)
  ExpiresByType text/html "access plus 1 week"
  ExpiresByType application/xhtml+xml "access plus 1 week"

  # Manifests
  ExpiresByType application/manifest+json "access plus 1 week"
  ExpiresByType application/x-web-app-manifest+json "access plus 1 week"
</IfModule>

# Add Cache-Control headers
<IfModule mod_headers.c>
  # Cache immutable assets for 1 year
  <FilesMatch "\.(jpg|jpeg|png|gif|webp|woff|woff2|ttf|otf|eot|svg)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Cache versioned JS/CSS for 1 year
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Cache unversioned files for 1 week (allow updates)
  <FilesMatch "\.(html|xml|txt|json)$">
    Header set Cache-Control "public, max-age=604800, must-revalidate"
  </FilesMatch>

  # Allow compression
  <FilesMatch "\.(js|css|html|xml|svg|json|woff|woff2)$">
    Header append Vary Accept-Encoding
  </FilesMatch>
</IfModule>

# Disable directory listing
Options -Indexes

# Set UTF-8 encoding
AddDefaultCharset utf-8
AddCharset UTF-8 .html .css .js .xml .json .php